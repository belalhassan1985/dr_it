# Database - change to your production PostgreSQL connection
DATABASE_URL="postgresql://user:password@localhost:5432/dr_it?schema=public"

# Auth - MUST change in production! Generate with: openssl rand -base64 48
AUTH_SECRET="REPLACE_WITH_RANDOM_64_CHAR_STRING"

# Admin credentials - MUST change in production!
ADMIN_EMAIL="admin@dr-it.local"
ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"
ADMIN_NAME="DR.IT Admin"

# Public site URL - used for SEO (sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL="https://dr-it.store"

# Store contact info (optional)
STORE_PHONE=""
STORE_WHATSAPP=""

# WAHA (WhatsApp HTTP API) — self-hosted WhatsApp messaging
# Install: docker run -it \
#   -e WAHA_API_KEY=your_key \
#   -e WAHA_PRINT_QR=false \
#   -p 3002:3000 \
#   devlikeapro/waha
# Then configure Base URL, API Key, and session via admin panel Settings → WhatsApp
# No env vars needed — all WAHA config is stored in DB settings